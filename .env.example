# TURN server configuration for PeerJS WebRTC connections.
# These are optional. When set, PeerJS will use the specified TURN server
# to relay traffic for peers that cannot establish a direct connection
# (e.g. when both peers are behind symmetric NATs).
#
# Copy this file to .env.local and fill in your credentials.
#
# VITE_TURN_URL      – TURN server URL, e.g. turn:your.turn.server:3478
# VITE_TURN_USERNAME – TURN server username
# VITE_TURN_CREDENTIAL – TURN server password / credential

VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
